<mvc:View controllerName="zov.controller.View1"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
    xmlns:f="sap.ui.layout.form"
    xmlns:core="sap.ui.core">

    <Page title="Calculadora de Média">

        <VBox class="sapUiSmallMargin">
            <f:Form id="formCalculadora" editable="true">

                <f:title>
                    <core:Title text="Notas"/>
                </f:title>

                <f:layout>
                    <f:ResponsiveGridLayout/>
                </f:layout>

                <f:formContainers>
                    <f:FormContainer>
                        <f:formElements>

                            <f:FormElement label="1° Bimestre">
                                <f:fields>
                                    <Input id="b1" type="Number"/>
                                </f:fields>
                            </f:FormElement>

                            <f:FormElement label="2° Bimestre">
                                <f:fields>
                                    <Input id="b2" type="Number"/>
                                </f:fields>
                            </f:FormElement>

                            <f:FormElement label="3° Bimestre">
                                <f:fields>
                                    <Input id="b3" type="Number"/>
                                </f:fields>
                            </f:FormElement>

                            <f:FormElement label="4° Bimestre">
                                <f:fields>
                                    <Input id="b4" type="Number"/>
                                </f:fields>
                            </f:FormElement>

                            <f:FormElement label="Resultado">
                                <f:fields>
                                    <Input id="resultado" editable="false"/>
                                </f:fields>
                            </f:FormElement>

                            <f:FormElement>
                                <f:fields>
                                    <Button text="Calcular" press="onCalc" type="Emphasized"/>
                                    <Button text="Limpar" press="onClick" type="Reject"/>
                                </f:fields>
                            </f:FormElement>

                            <f:FormElement label="">
                                <f:fields>
                                    <ObjectStatus
							        class="sapUiSmallMarginBottom"
                                    id="status"
                                    inverted="true"
							        text=""
                                    visible="false"
							        state="None" />
                                </f:fields>
                            </f:FormElement>

                        </f:formElements>
                    </f:FormContainer>
                </f:formContainers>
            </f:Form>
        </VBox>

    </Page>
</mvc:View>